<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="f6e1f061-0f67-4638-b715-f5b248eb3a67">
        <File Id="ClipboardTTSMonitor.exe" Source="..\build\Release\ClipboardTTSMonitor.exe" KeyPath="yes" />
      </Component>
      <Component Id="AppIcon" Guid="98765432-1234-4321-a1b2-c3d4e5f60718">
        <File Id="app.ico" Source="..\res\app.ico" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="CONFIGFOLDER">
      <Component Id="ConfigIni" Guid="a1b2c3d4-e5f6-4890-a123-b4c5d6e7f809" NeverOverwrite="yes">
        <RegistryValue Root="HKCU" Key="Software\ClipboardTTSMonitor" Name="ConfigInstalled" Type="integer" Value="1" KeyPath="yes"/>
      </Component>

      <Component Id="AutoStartRegistry" Guid="12345678-abcd-ef01-2345-67890abcdef1">
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="ClipboardTTSMonitor"
                       Type="string"
                       Value="[INSTALLFOLDER]ClipboardTTSMonitor.exe"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
