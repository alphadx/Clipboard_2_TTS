{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja-x64-debug",
      "displayName": "Ninja x64 Debug",
      "description": "Configurar proyecto con Ninja + MSVC (x64, Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/x64-Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "ninja-x64-release",
      "displayName": "Ninja x64 Release",
      "description": "Configurar proyecto con Ninja + MSVC (x64, Release)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/x64-Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "17"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ninja-x64-debug",
      "configurePreset": "ninja-x64-debug",
      "configuration": "Debug",
      "jobs": 0
    },
    {
      "name": "ninja-x64-release",
      "configurePreset": "ninja-x64-release",
      "configuration": "Release",
      "jobs": 0
    }
  ]
}
